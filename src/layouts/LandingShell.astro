---
import Base from "@/layouts/Base.astro";
import { ClientRouter } from "astro:transitions";

import SettingsModal from "@/components/SettingsModal";
import { getPwaRouteBootstrapScript } from "@/lib/pwaRoute";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const FOOTER_LINKS = [
  { href: "/about", label: "About" },
  { href: "/features", label: "Features" },
  { href: "/privacy", label: "Privacy" },
  { href: "/changelog", label: "Changelog" },
  {
    href: "https://github.com/abijith-suresh/unwrapped-tools",
    label: "GitHub",
    external: true,
  },
];
---

<Base title={title} description={description} ogImage={ogImage}>
  <Fragment slot="head">
    <script is:inline set:html={getPwaRouteBootstrapScript()} />
    <ClientRouter />
  </Fragment>

  <!--
    Single wrapper owns all horizontal padding.
    main and footer are direct siblings — left edges guaranteed to align.
  -->
  <div class="ls-page">
    <main class="ls-main">
      <slot />
    </main>

    <footer class="ls-footer">
      <nav aria-label="Site navigation" class="ls-footer-nav">
        {
          FOOTER_LINKS.map((link) => (
            <a
              href={link.href}
              class="ls-footer-link"
              {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              {link.label}
            </a>
          ))
        }
        <span class="ls-footer-sep" aria-hidden="true">&middot;</span>
        <button
          class="ls-footer-link ls-footer-settings"
          aria-label="Open settings"
          onclick="document.dispatchEvent(new Event('open-settings'))"
        >
          Settings
        </button>
      </nav>
    </footer>
  </div>

  <!-- Modal lives outside ls-page so it isn't clipped by any overflow -->
  <SettingsModal client:load hideButton />
</Base>

<style>
  /*
   * ls-page: one flex column, one source of horizontal padding.
   * Full-viewport-width — background fills edge to edge, no island effect.
   * Both main and footer share the same left/right edges.
   */
  .ls-page {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    padding-inline: clamp(2rem, 6vw, 7rem);
  }

  .ls-main {
    flex: 1;
    padding-top: clamp(2.5rem, 8vh, 5rem);
  }

  .ls-footer {
    padding: 2rem 0 2.5rem;
    border-top: 1px solid var(--border);
  }

  .ls-footer-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  /* Separator before Settings — visually separates action from nav links */
  .ls-footer-sep {
    color: var(--text-muted);
    opacity: 0.45;
    margin-inline: -0.5rem;
  }

  .ls-footer-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.1s;
  }

  .ls-footer-link:hover {
    color: var(--text-primary);
  }

  .ls-footer-settings {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .ls-footer-link {
      transition: none;
    }
  }
</style>
